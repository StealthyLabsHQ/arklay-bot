# ============================================================
# discord-bot — Environment variables
# Copy this file to .env and fill in the values
# NEVER commit .env
# ============================================================

# --- Core (required) ---
DISCORD_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_discord_application_id_here

# --- Core (optional) ---
# Comma-separated guild IDs for instant command deployment
# Multiple: GUILD_ID=111111111,222222222,333333333
# Empty or removed: global deployment (may take up to 1 hour)
GUILD_ID=your_dev_guild_id_here

# --- Bot owner (optional) ---
# Your Discord user ID — gets boosted daily AI request limits
BOT_OWNER_ID=your_discord_user_id_here
# Multiplier for owner limits (0-20, default 5). E.g. 10 = 10x normal limits
BOT_OWNER_MULTIPLIER=5

# --- Bot prefix (optional) ---
# Text command prefix (e.g. ".help" or "!help")
BOT_PREFIX=.
# Bot name prefix (e.g. "specter play" or "specter ask")
BOT_NAME=specter

# --- Music module (optional) ---
# Required to resolve Spotify links → YouTube
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# --- AI module (optional) ---
# Option A — Direct Anthropic API key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Option B — Claude via Google Cloud Vertex AI (uses your GCP billing)
# Fill these instead of ANTHROPIC_API_KEY to route Claude through Vertex AI
GOOGLE_CLOUD_PROJECT=your_gcp_project_id_here
GOOGLE_CLOUD_REGION=us-east5
# Path to your service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=C:/path/to/service-account-key.json

# Enables the Gemini provider (gemini-2.0-flash) + /imagine command
GOOGLE_AI_API_KEY=your_google_ai_api_key_here
